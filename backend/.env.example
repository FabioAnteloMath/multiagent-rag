# LLM Provider API Keys (all optional — only set the ones you plan to use)

# MiniMax (Cloud, default)
# Get yours at: https://api.minimax.io
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.7

# Groq (Free tier, OpenAI-compatible, fast inference)
# Get yours at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (Free tier with rate limits)
# Get yours at: https://aistudio.google.com/app/apikey
# Note: gemini-1.5-flash was retired in early 2026. The current
# free-tier default is gemini-2.5-flash (1500 RPD, GA).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (Local, default — free)
# Install: https://ollama.ai
# Then: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# LLM Quota & Fallback (protect free tier)
# ---------------------------------------------------------------------------
# The app tracks every LLM request in a SQLite `usage_log` table and
# refuses to call a provider whose 24h rolling count has reached the
# configured limit. When a provider is exhausted (or returns 429), the
# ProviderRouter walks FALLBACK_CHAIN until one succeeds.

# Set to false to disable enforcement (useful for benchmarking).
QUOTA_ENABLED=true

# Daily request limit per provider (rolling 24h window).
# Defaults are 10% under the published free tier of each provider.
# Set to 0 (or very high) for a provider you don't want to limit.
QUOTA_GROQ_DAILY=13000
QUOTA_GEMINI_DAILY=1400
QUOTA_MINIMAX_DAILY=5000
QUOTA_OLLAMA_DAILY=999999

# Window length in hours. Most billing windows are 24h UTC.
QUOTA_WINDOW_HOURS=24

# Fallback order — first provider with quota remaining wins.
# (Comma-separated. The agent's preferred provider is tried first
# regardless of its position in this list.)
FALLBACK_CHAIN=groq,gemini,minimax,ollama
